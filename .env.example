# MCP Company News Server — Environment Variables
# Copy this file to .env and fill in your API keys.

# Required: NewsAPI key (free tier available at https://newsapi.org/register)
NEWSAPI_KEY=your_newsapi_key_here

# Required: Anthropic API key for AI-powered relevance filtering
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: custom path for the company storage file
# Default: ~/.mcp_news_server/companies.json
# COMPANIES_STORAGE_PATH=/path/to/companies.json
